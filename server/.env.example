# pyUniBParcer server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
ENVIRONMENT=production

# Authentication
API_USERNAME=admin
API_PASSWORD=change_me_in_production

# Proxy
PROXY_STORAGE_PATH=proxies.json
PROXY_CHECK_URL=https://httpbin.org/ip
PROXY_CHECK_TIMEOUT=15

# Botasaurus
ENABLE_BOTASAURUS_SERVER=true
